    "test:e2e": "playwright test",
    "gate:set": "node scripts/gate-set.mjs"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "5.2.11",
    "@fontsource/italianno": "^5.2.8",
    "@vueuse/core": "14.3.0",
    "pinia": "3.0.4",
    "vue": "3.5.33",
    "vue-router": "5.0.6",
    "yaml": "^2.8.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.48.0",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.0",
    "globals": "16.0.0",
    "jsdom": "25.0.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vitest": "3.0.0",
    "vue-tsc": "3.2.7"
  }
